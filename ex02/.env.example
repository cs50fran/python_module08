# Matrix Configuration - copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control!

# Environment mode: 'development' or 'production'
MATRIX_MODE=very_nice

# Database connection string
DATABASE_URL=sqlite:///matrix_dev.db

# Secret key for external API services
API_KEY=your_api_key_here

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# URL for the resistance network endpoint
ZION_ENDPOINT=http://localhost:8080/zion
